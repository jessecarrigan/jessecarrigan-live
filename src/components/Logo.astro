---
const {name} = Astro.props;
---

<a href="/" class="logo">
	{name}
</a>

<style>
	.logo {
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--ink);
		text-decoration: none;
		transition: opacity 0.2s;
	}
	.logo:hover {
		opacity: 0.6;
	}
</style>
