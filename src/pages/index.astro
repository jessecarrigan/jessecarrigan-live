---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jesse Carrigan" subtitle="Composer for Media">
  <main>

    <div class="reel-outer">
      <div class="reel">
        <iframe
          src="https://player.vimeo.com/video/1186759705?badge=0&autopause=0&player_id=0&app_id=58479"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          title="Jesse Carrigan - Portfolio Reel"
        ></iframe>
      </div>
    </div>
    <script src="https://player.vimeo.com/api/player.js"></script>

    <div class="split-outer">
      <div class="split">
        <div class="split-left">
          <p class="label">About Me</p>
          <p class="bio-text">Some of my earliest memories are music-related - our family piano, hearing the Star Wars theme for the first time, and dancing around to the song "Eye of the Tiger" by Survivor. I wrote my first song when I was about 3 (something about George Washington - if only I had a recording, because it was definitely a bop). Now I write music for film, tv, and media, finding moments to focus on with the spotlight that only the right sound can provide.</p>
        </div>

        <div class="split-right">
          <img src="/img/jesse-carrigan.jpg" alt="Jesse Carrigan" />
        </div>
      </div>
    </div>

  </main>
</Layout>

<style>
  /* ── Reel ─────────────────────────────────────────── */
  .reel-outer {
    padding: 1rem;
    background: var(--cream);
    border-top: 1px solid var(--cream-dark);
  }

  .reel {
    position: relative;
    padding-top: 50%;
    max-width: 100rem;
    margin: 0 auto;
    overflow: hidden;
  }

  .reel iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* ── Split ────────────────────────────────────────── */
  .split-outer {
    border-top: 1px solid var(--cream-dark);
  }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 100rem;
    margin: 0 auto;
  }

  .split-left {
    background: var(--cream);
    padding: 5.6rem 4.8rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 2rem;
  }

  .bio-text {
    font-family: var(--font-body);
    font-size: clamp(1.5rem, 1.6vw, 1.8rem);
    font-weight: 400;
    color: var(--ink-mid);
    line-height: 1.8;
  }

  .split-right {
    overflow: hidden;
  }

  .split-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 720px) {
    .reel-outer {
      padding: 1rem;
    }

    .split {
      grid-template-columns: 1fr;
    }

    .split-right {
      order: -1;
      aspect-ratio: 2462 / 3283;
      max-height: 80vh;
    }

    .split-right img {
      object-position: center center;
    }

    .split-left {
      padding: 4rem 2.4rem;
    }
  }
</style>
