---
import Layout from '../layouts/Layout.astro';

const EMAIL = "jesse@jessecarrigan.live";
---

<Layout title="Jesse Carrigan">
  <main>

    <header class="site-header">
      <h1 class="name">Jesse Carrigan</h1>
      <h2 class="label">Composer for Media</h2>
    </header>

    <div class="reel">
      <div class="reel-controls">
        <button id="reel-play" class="reel-play" aria-label="Play portfolio reel" type="button" disabled>
          <svg class="icon icon-play" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z" fill="currentColor"/>
          </svg>
          <svg class="icon icon-pause" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 5h4v14H6zM14 5h4v14h-4z" fill="currentColor"/>
          </svg>
        </button>
        <div id="reel-waveform" class="reel-waveform"></div>
      </div>
      <p class="reel-label">Portfolio Reel</p>
    </div>

    <script>
      import WaveSurfer from 'wavesurfer.js';

      const btn = document.getElementById('reel-play') as HTMLButtonElement | null;
      const container = document.getElementById('reel-waveform');

      if (btn && container) {
        const ws = WaveSurfer.create({
          container,
          url: '/audio/reel.mp3',
          waveColor: '#7A7168',
          progressColor: '#C4A46B',
          cursorColor: '#F7F3EC',
          cursorWidth: 1,
          barWidth: 2,
          barGap: 1,
          barRadius: 1,
          height: 72,
          normalize: true,
        });

        const setPlaying = (playing: boolean) => {
          btn.classList.toggle('playing', playing);
          btn.setAttribute('aria-label', playing ? 'Pause portfolio reel' : 'Play portfolio reel');
        };

        btn.addEventListener('click', () => ws.playPause());
        ws.on('ready', () => { btn.disabled = false; });
        ws.on('play', () => setPlaying(true));
        ws.on('pause', () => setPlaying(false));
        ws.on('finish', () => setPlaying(false));
      }
    </script>

    <div class="split">
      <div class="split-left">
        <p class="label">About Me</p>
        <p class="bio-text">Some of my earliest memories are music-related - our family piano, hearing the Star Wars theme for the first time, and dancing around to the song "Eye of the Tiger" by Survivor. I wrote my first song when I was about 3 (something about George Washington - if only I had a recording, because it was definitely a bop). Now I write music for film, tv, and media, finding moments to focus on with the spotlight that only the right sound can provide.</p>
      </div>

      <div class="split-right">
        <img src="/img/jesse-carrigan.jpg" alt="Jesse Carrigan" />
      </div>
    </div>

    <footer class="contact">
      <h2 class="label">Contact</h2>
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </footer>

  </main>
</Layout>

<style>
  /* ── Header ───────────────────────────────────────── */
  .site-header {
    padding: 5.6rem 4.8rem 4.8rem;
    text-align: center;
    background: var(--cream);
  }

  .name {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 9.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .site-header .label {
    margin-top: 1.2rem;
  }

  /* ── Reel ─────────────────────────────────────────── */
  .reel {
    background: var(--charcoal);
    border-top: 1px solid var(--cream-dark);
    padding: 8rem 4.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.4rem;
  }

  .reel-controls {
    display: flex;
    align-items: center;
    gap: 3.2rem;
    width: 100%;
    max-width: 96rem;
  }

  .reel-waveform {
    flex: 1;
    min-width: 0;
  }

  .reel-play {
    flex: 0 0 auto;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    border: 1px solid var(--gold-light);
    background: transparent;
    color: var(--cream);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.25s ease, color 0.25s ease, transform 0.2s ease, border-color 0.25s ease, opacity 0.25s ease;
  }

  .reel-play:hover:not(:disabled) {
    background: var(--gold);
    color: var(--white);
    border-color: var(--gold);
    transform: scale(1.04);
  }

  .reel-play:disabled {
    cursor: wait;
    opacity: 0.45;
  }

  .reel-play .icon {
    width: 3rem;
    height: 3rem;
    display: block;
  }

  .reel-play .icon-pause,
  .reel-play.playing .icon-play {
    display: none;
  }

  .reel-play.playing .icon-pause {
    display: block;
  }

  .reel-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-dark);
  }

  /* ── Split ────────────────────────────────────────── */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 44rem;
    border-top: 1px solid var(--cream-dark);
  }

  .split-left {
    background: var(--cream);
    padding: 5.6rem 4.8rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 2rem;
  }

  .bio-text {
    font-family: var(--font-body);
    font-size: clamp(1.5rem, 1.6vw, 1.8rem);
    font-weight: 400;
    color: var(--ink-mid);
    line-height: 1.8;
  }

  .split-right {
    overflow: hidden;
  }

  .split-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Contact ──────────────────────────────────────── */
  .contact {
    padding: 4rem 2.4rem 6rem;
    text-align: center;
    border-top: 1px solid var(--cream-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .contact a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--ink-light);
    transition: color 0.2s ease;
  }

  .contact a:hover {
    color: var(--gold);
  }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 720px) {
    .site-header {
      padding: 4rem 2.4rem 3.2rem;
    }

    .reel {
      padding: 5.6rem 2.4rem;
    }

    .reel-controls {
      flex-direction: column;
      gap: 2.4rem;
    }

    .split {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .split-right {
      order: -1;
      aspect-ratio: 2462 / 3283;
      max-height: 80vh;
    }

    .split-right img {
      object-position: center;
    }

    .split-left {
      padding: 4rem 2.4rem;
    }
  }
</style>
