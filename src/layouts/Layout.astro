---
import "../styles/global.css"

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
const EMAIL = "jesse@jessecarrigan.live";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Jesse Carrigan — vocalist, composer, and songwriter." />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap"
      rel="stylesheet"
    />
    <!-- 100% privacy-first analytics -->
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
    <noscript><img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade"/></noscript>
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <h1 class="name"><a href="/">Jesse Carrigan</a></h1>
      {subtitle && <p class="label">{subtitle}</p>}
    </header>

    <slot />

    <footer class="site-footer">
      <h2 class="label">Contact</h2>
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </footer>
  </body>
</html>

<style>
  .site-header {
    padding: 5.6rem 4.8rem 4.8rem;
    text-align: center;
    background: var(--cream);
  }

  .name {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 9.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .name a {
    color: inherit;
    text-decoration: none;
  }

  .site-header .label {
    margin-top: 1.2rem;
  }

  .site-footer {
    padding: 4rem 2.4rem 6rem;
    text-align: center;
    border-top: 1px solid var(--cream-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .site-footer a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--ink-light);
    transition: color 0.2s ease;
  }

  .site-footer a:hover {
    color: var(--gold);
  }

  @media (max-width: 720px) {
    .site-header {
      padding: 4rem 2.4rem 3.2rem;
    }
  }
</style>
