---
import Layout from '../layouts/Layout.astro';

// Add Vimeo entries here. `id` is the numeric Vimeo video ID.
const videos: { id: string; title: string }[] = [
  { id: 'VIMEO_ID_1', title: 'Rescore 1' },
  { id: 'VIMEO_ID_2', title: 'Rescore 2' },
  { id: 'VIMEO_ID_3', title: 'Rescore 3' },
];

const embedUrl = (id: string) =>
  `https://player.vimeo.com/video/${id}?badge=0&autopause=0&player_id=0&app_id=58479`;
---

<Layout title="Rescores — Jesse Carrigan">
  <main>

    <header class="page-header">
      <h1 class="name">Rescores</h1>
      <h2 class="label">Reimagined Scenes</h2>
    </header>

    <section class="grid">
      {videos.map(({ id, title }) => (
        <figure class="card">
          <div class="frame">
            <iframe
              src={embedUrl(id)}
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              title={title}
            ></iframe>
          </div>
          <figcaption>{title}</figcaption>
        </figure>
      ))}
    </section>

  </main>
  <script src="https://player.vimeo.com/api/player.js"></script>
</Layout>

<style>
  .page-header {
    padding: 5.6rem 4.8rem 4.8rem;
    text-align: center;
    background: var(--cream);
  }

  .name {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 9.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .page-header .label {
    margin-top: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(36rem, 1fr));
    gap: 4rem;
    padding: 5.6rem 4.8rem 8rem;
    border-top: 1px solid var(--cream-dark);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .frame {
    position: relative;
    padding-top: 56.25%;
    background: var(--charcoal);
    border-radius: 4px;
    overflow: hidden;
  }

  .frame iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  figcaption {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  @media (max-width: 720px) {
    .page-header {
      padding: 4rem 2.4rem 3.2rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 3.2rem;
      padding: 4rem 2.4rem 6rem;
    }
  }
</style>
