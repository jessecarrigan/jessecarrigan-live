---
const {width, height} = Astro.props;
const socialLinks = [
	{
		title: 'LinkedIn',
		icon: 'simple-icons:linkedin',
		href: 'https://www.linkedin.com/in/jesse-carrigan/',
	},
	{
		title: 'Instagram',
		icon: 'mdi:instagram',
		href: 'https://www.instagram.com/jesse_carrigan',
	},
];
---

<div class="social-icons">
	{
		socialLinks.map((data) => (
			<a
				href={data.href}
				target="_blank"
				rel="nofollow noreferrer noopener"
				class="social-icon"
				aria-label={data.title}
			>
				<iconify-icon
					icon={data.icon}
					width={width}
					height={height}
				/>
			</a>
		))
	}
</div>

<style>
	.social-icons {
		display: flex;
		align-items: center;
		gap: 1.6rem;
	}

	.social-icon {
		color: rgba(254, 252, 248, 0.45);
		transition: color 0.2s;
		display: flex;
		align-items: center;
	}

	.social-icon:hover {
		color: var(--gold-light);
	}
</style>
