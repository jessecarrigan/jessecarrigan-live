---

---

<section id="portfolio" class="listen">
	<div class="listen__container">
		<span class="listen__label">Listen</span>
		<h2 class="listen__heading">The Work</h2>
		<span class="listen__rule"></span>

		<div class="listen__block">
			<h3 class="listen__track-title">As Heard on TV</h3>
			<p class="listen__track-desc">
				Rock and vocal compositions from TV and media.
			</p>
			<div class="listen__player">
				<iframe
					id="disco-playlist-17031939"
					name="disco-playlist-17031939"
					allowfullscreen
					style="border:0"
					class="disco-embed"
					src="https://ithilien-songs.disco.ac/e/p/17031939?download=false&s=-TSGSeuL0-JV5PtRck7759i7KzQ%3AsZ9rsTBD&artwork=true&color=%238C6A3F&theme=light"
					width="480"
					height="395"></iframe>
			</div>
		</div>

		<div class="listen__divider"></div>

		<div class="listen__block">
			<h3 class="listen__track-title">Rock Reel</h3>
			<p class="listen__track-desc">
				A selection of original instrumental rock compositions.
			</p>
			<div class="listen__player">
				<iframe
					id="disco-playlist-25346737"
					name="disco-playlist-25346737"
					allowfullscreen
					style="border:0"
					class="disco-embed"
					src="https://ithilien-songs.disco.ac/e/p/25346737?download=false&s=l-_dyX2AfzOY1f7rpWplbFq_VSY%3APIdWblCI&artwork=true&color=%238C6A3F&theme=light"
					width="480"
					height="395"></iframe>
			</div>
		</div>
	</div>
</section>

<style>
	.listen {
		width: 100%;
		background: var(--cream-alt);
		border-top: 1px solid var(--cream-dark);
	}

	.listen__container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.6rem;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 10rem 2.2rem;
	}

	.listen__label {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--gold);
	}

	.listen__heading {
		font-family: var(--font-display);
		font-size: var(--text-3xl);
		font-weight: 400;
		color: var(--ink);
		line-height: 1.05;
	}

	.listen__rule {
		display: block;
		width: 4.4rem;
		height: 1px;
		background: var(--gold);
		margin-bottom: 2.4rem;
	}

	.listen__block {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.2rem;
		width: 100%;
	}

	.listen__track-title {
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: 400;
		color: var(--ink);
	}

	.listen__track-desc {
		font-family: var(--font-body);
		font-size: var(--text-base);
		font-weight: 300;
		color: var(--ink-light);
		line-height: 1.6;
		max-width: 50rem;
	}

	.listen__player {
		margin-top: 1.6rem;
		max-width: 100%;
	}

	.disco-embed {
		max-width: 100%;
	}

	.listen__divider {
		width: 6rem;
		height: 1px;
		background: var(--cream-dark);
		margin: 3.2rem 0;
	}

	@media screen and (max-width: 600px) {
		.listen__container {
			padding: 7rem 2rem;
		}

		.listen__heading {
			font-size: var(--text-2xl);
		}

		.disco-embed {
			width: 100%;
			height: 320px;
		}
	}
</style>
