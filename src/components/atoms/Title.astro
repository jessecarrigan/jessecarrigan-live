---
const { contenido, margin } = Astro.props;
---

<h2 class="section-title" style={margin ? `margin-bottom:${margin}` : ''}>{contenido}</h2>

<style>
	.section-title {
		font-family: var(--font-display);
		font-size: var(--text-3xl);
		font-weight: 400;
		color: var(--ink);
		line-height: 1.05;
	}
</style>
